    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@payloadcms/ui": "^4.0.0-canary.8",
    "payload": "^4.0.0-canary.8",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
