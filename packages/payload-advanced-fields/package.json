{
  "name": "@studio123/payload-advanced-fields",
  "version": "1.0.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./code-field": {
      "types": "./dist/code-field/index.d.ts",
      "default": "./dist/code-field/index.js"
    },
    "./link-field": {
      "types": "./dist/link-field/index.d.ts",
